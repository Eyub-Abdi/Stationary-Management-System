# compiled output
/dist
/node_modules
/build

# TypeScript incremental build cache (regenerated on every build — never track)
*.tsbuildinfo

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# IDE
.idea
.vscode/*
!.vscode/extensions.json
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Tests
/coverage
/.nyc_output

# Prisma
prisma/*.db

# Uploaded files (served from disk; back up separately in production)
/uploads

# Database dumps (created/uploaded by the in-app backup feature)
/backups

# Windows service wrapper generated by node-windows on `npm run service:install`
/scripts/daemon
