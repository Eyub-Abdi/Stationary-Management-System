// ============================================================================
// KJ Stationery Management System — Prisma Schema
// PostgreSQL · Production grade
//
// Design principles:
//  - Money is stored as Decimal(14,2) — never floats. (decimal.js in app layer)
//  - All historical financial rows store immutable SNAPSHOTS (name + unit price).
//  - Inventory is valued with FIFO via InventoryBatch.remainingQuantity.
//  - Every stock change writes an InventoryMovement (full audit trail).
//  - Critical actions write an immutable AuditLog row.
//  - Soft-delete is avoided for transactional data (sales/purchases are immutable);
//    catalog entities use a status flag instead of hard delete.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum PricingType {
  PER_PAGE
  FIXED
}

enum SaleItemType {
  PRODUCT
  SERVICE
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  DEPOSIT
  WITHDRAWAL
}

// How a sale or purchase is settled. CREDIT leaves an outstanding balance on
// the customer (receivable) or supplier (payable) that is paid down over time.
enum PaymentMethod {
  CASH
  CREDIT
}

// Which packaging unit a line was transacted in (dual-unit products).
// BASE = the smallest sellable unit (piece); BULK = the larger packaging unit.
enum SellUnit {
  BASE
  BULK
}

// Generic counter scope for human-readable sequential document numbers.
enum SequenceType {
  INVOICE
  TRANSACTION
  PURCHASE
  RETURN
}

// ----------------------------------------------------------------------------
// Identity & Access
// ----------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  // Per-staff grants (admins always have full access regardless of this list).
  // Values come from common/permissions.ts, e.g. ["products","reports"].
  permissions  String[]
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  refreshTokens        RefreshToken[]
  sales                Sale[]
  saleReturns          SaleReturn[]
  purchases            Purchase[]
  expenses             Expense[]
  cashSessions         CashSession[]
  cashMovements        CashMovement[]
  inventoryMovements   InventoryMovement[]
  inventoryAdjustments InventoryAdjustment[]
  customerPayments     CustomerPayment[]
  supplierPayments     SupplierPayment[]
  auditLogs            AuditLog[]
  closedPeriods        AccountingPeriod[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

// Refresh-token rotation: store only a hash, support revocation & reuse-detection.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  // points to the token that replaced this one (rotation chain / reuse detection)
  replacedById String? @db.Uuid
  createdByIp  String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ----------------------------------------------------------------------------
// Catalog: Products & Categories
// ----------------------------------------------------------------------------

model Category {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    Product[]

  @@map("categories")
}

// A reusable packaging/measure unit (e.g. pcs, Box, Roll, Ream) the owner
// registers and reuses when receiving stock by the pack in Purchases.
model Unit {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("units")
}

// A Product is the grouping/template (name, category, packaging). Its sellable
// SKUs — with their own price, stock and FIFO cost — live in ProductVariant.
// Every product has at least one variant (a single-variant product behaves like
// a plain product).
model Product {
  id            String        @id @default(uuid()) @db.Uuid
  sku           String        @unique // product group code; each variant has its own sku
  name          String
  imageUrl      String?
  categoryId    String?       @db.Uuid

  // --- Dual unit of measure (shared by all variants) ------------------------
  // Stock & COGS are ALWAYS tracked internally in base units (pieces). A product
  // may optionally be sold/bought in a larger "bulk" unit (box, carton, ream).
  baseUnit         String   @default("pcs") // name of the smallest sellable unit
  bulkUnit         String?  // larger packaging unit name; null = single-unit product
  unitSize         Int      @default(1) // base units contained in one bulk unit

  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category           Category?           @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  saleItems          SaleItem[]
  purchaseItems      PurchaseItem[]
  inventoryBatches   InventoryBatch[]
  inventoryMovements InventoryMovement[]
  adjustments        InventoryAdjustment[]

  @@index([categoryId])
  @@index([status])
  @@index([name])
  @@map("products")
}

// A sellable variant of a product (e.g. "Blue", "Red", "A4 80gsm"). Holds the
// price, live stock (base units) and reference cost. Inventory batches, sales,
// purchases, movements and adjustments all key on the variant.
model ProductVariant {
  id            String        @id @default(uuid()) @db.Uuid
  productId     String        @db.Uuid
  sku           String        @unique
  label         String // human label shown at the counter, e.g. "Blue"
  // Reference selling price PER BASE UNIT (piece). Snapshotted at sale time.
  sellingPrice  Decimal       @db.Decimal(14, 2)
  // Optional wholesale price PER BASE UNIT (piece). Null = no wholesale tier.
  wholesalePrice Decimal?     @db.Decimal(14, 2)
  // Reference/last buying price PER BASE UNIT — true COGS comes from batches.
  buyingPrice   Decimal       @db.Decimal(14, 2) @default(0)
  // Legacy: selling price for one whole bulk unit (no longer set; sells are per piece).
  bulkSellingPrice Decimal?   @db.Decimal(14, 2)
  // Denormalized live stock IN BASE UNITS; kept consistent with batches.
  currentStock  Int           @default(0)
  minStockLevel Int           @default(0)
  // The variant created from the original product on migration / the implicit
  // variant of a single-variant product.
  isDefault     Boolean       @default(false)
  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  product            Product             @relation(fields: [productId], references: [id])
  saleItems          SaleItem[]
  purchaseItems      PurchaseItem[]
  inventoryBatches   InventoryBatch[]
  inventoryMovements InventoryMovement[]
  adjustments        InventoryAdjustment[]
  // Service option components that consume this product (e.g. printing uses this paper).
  serviceComponents  ServiceComponent[]
  // Per-sale-line consumption snapshots that drew this product down.
  saleConsumptions   SaleItemConsumption[]

  @@index([productId])
  @@index([status])
  @@map("product_variants")
}

// ----------------------------------------------------------------------------
// Catalog: Services
// ----------------------------------------------------------------------------

// A service (e.g. "Printing B&W"). Its priced options — paper sizes like A4/A3 —
// are ServiceVariants. Every service has at least one variant.
model Service {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @unique
  // Optional Material Symbols icon name for display (e.g. "print"). Cosmetic only.
  icon        String?
  pricingType PricingType
  status      ServiceStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  variants  ServiceVariant[]
  saleItems SaleItem[]

  @@index([status])
  @@map("services")
}

// A priced option of a service, e.g. "A4" / "A3". Holds the price; the parent
// service holds the pricing model (per page vs fixed). Snapshotted at sale time.
// The products it consumes (its bill of materials) live in ServiceComponent.
model ServiceVariant {
  id        String        @id @default(uuid()) @db.Uuid
  serviceId String        @db.Uuid
  label     String // e.g. "A4", "A3"
  unitPrice Decimal       @db.Decimal(14, 2)
  isDefault Boolean       @default(false)
  status    ServiceStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  service    Service            @relation(fields: [serviceId], references: [id])
  components ServiceComponent[]
  saleItems  SaleItem[]

  @@index([serviceId])
  @@index([status])
  @@map("service_variants")
}

// One line of a service option's bill of materials: a product the option
// consumes and how much. qty is a whole count of BASE units (pieces); fractional
// consumption is modelled by the product's unitSize yield, not fractional stock.
model ServiceComponent {
  id               String  @id @default(uuid()) @db.Uuid
  serviceVariantId String  @db.Uuid
  variantId        String  @db.Uuid
  // Base units consumed per page (perPage=true) or per job (perPage=false).
  qty              Int     @default(1)
  perPage          Boolean @default(true)
  createdAt        DateTime @default(now())

  serviceVariant ServiceVariant @relation(fields: [serviceVariantId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id])

  @@index([serviceVariantId])
  @@index([variantId])
  @@map("service_components")
}

// ----------------------------------------------------------------------------
// Suppliers & Purchases (stock IN)
// ----------------------------------------------------------------------------

model Supplier {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean    @default(true)
  // Outstanding amount we OWE this supplier (accounts payable). Updated atomically
  // when recording credit purchases and supplier payments.
  balance   Decimal    @db.Decimal(14, 2) @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  payments  SupplierPayment[]

  @@index([name])
  @@map("suppliers")
}

// ----------------------------------------------------------------------------
// Customers / debtors (accounts receivable)
// ----------------------------------------------------------------------------

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  // Outstanding amount this customer OWES us (accounts receivable). Invariant:
  // balance == SUM(amountDue) over the customer's COMPLETED credit sales.
  balance   Decimal  @db.Decimal(14, 2) @default(0)
  // Maximum receivable allowed. NULL = unlimited credit.
  creditLimit Decimal? @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales    Sale[]
  payments CustomerPayment[]

  @@index([name])
  @@map("customers")
}

// A repayment received from a customer against their outstanding balance.
model CustomerPayment {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @db.Uuid
  userId        String   @db.Uuid
  cashSessionId String?  @db.Uuid
  saleId        String?  @db.Uuid // optional: payment earmarked to a specific sale
  amount        Decimal  @db.Decimal(14, 2)
  notes         String?
  idempotencyKey String? @unique
  createdAt     DateTime @default(now())

  customer    Customer     @relation(fields: [customerId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  sale        Sale?        @relation(fields: [saleId], references: [id])
  allocations CustomerPaymentAllocation[]

  @@index([customerId])
  @@index([cashSessionId])
  @@index([createdAt])
  @@map("customer_payments")
}

// How a repayment was applied across specific invoices (accounts-receivable
// allocation). One payment can settle several invoices oldest-first.
model CustomerPaymentAllocation {
  id        String   @id @default(uuid()) @db.Uuid
  paymentId String   @db.Uuid
  saleId    String   @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  payment CustomerPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  sale    Sale            @relation(fields: [saleId], references: [id])

  @@index([paymentId])
  @@index([saleId])
  @@map("customer_payment_allocations")
}

// A payment made TO a supplier against what we owe them.
model SupplierPayment {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @db.Uuid
  userId        String   @db.Uuid
  cashSessionId String?  @db.Uuid
  purchaseId    String?  @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  notes         String?
  idempotencyKey String? @unique
  createdAt     DateTime @default(now())

  supplier    Supplier     @relation(fields: [supplierId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  purchase    Purchase?    @relation(fields: [purchaseId], references: [id])

  @@index([supplierId])
  @@index([cashSessionId])
  @@index([createdAt])
  @@map("supplier_payments")
}

model Purchase {
  id             String   @id @default(uuid()) @db.Uuid
  purchaseNumber String   @unique
  supplierId     String?  @db.Uuid
  userId         String   @db.Uuid
  cashSessionId  String?  @db.Uuid // session the cash portion was paid from
  purchaseDate   DateTime
  totalCost      Decimal  @db.Decimal(14, 2)
  // Payment settlement. CREDIT requires a supplier and leaves amountDue payable.
  paymentMethod  PaymentMethod @default(CASH)
  amountPaid     Decimal  @db.Decimal(14, 2) @default(0)
  amountDue      Decimal  @db.Decimal(14, 2) @default(0)
  notes          String?
  // Idempotency: a repeated request with the same key returns the original row.
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())

  supplier    Supplier?        @relation(fields: [supplierId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  cashSession CashSession?     @relation(fields: [cashSessionId], references: [id])
  items       PurchaseItem[]
  batches     InventoryBatch[]
  payments    SupplierPayment[]

  @@index([supplierId])
  @@index([userId])
  @@index([cashSessionId])
  @@index([purchaseDate])
  @@map("purchases")
}

model PurchaseItem {
  id                  String   @id @default(uuid()) @db.Uuid
  purchaseId          String   @db.Uuid
  productId           String   @db.Uuid
  variantId           String   @db.Uuid
  productNameSnapshot String
  // quantity is expressed in the transacted unit (unitLabel); unitSize converts
  // to base units for inventory. quantity * unitSize = base units (pieces) received.
  quantity            Int
  unitLabel           String   @default("pcs")
  unitSize            Int      @default(1)
  unitCost            Decimal  @db.Decimal(14, 2) // cost per transacted unit
  lineTotal           Decimal  @db.Decimal(14, 2)

  purchase Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant  @relation(fields: [variantId], references: [id])
  batch    InventoryBatch?

  @@index([purchaseId])
  @@index([productId])
  @@index([variantId])
  @@map("purchase_items")
}

// ----------------------------------------------------------------------------
// FIFO inventory batches (the source of truth for COGS)
// remainingQuantity is decremented FIFO (oldest purchaseDate first) on sale.
// ----------------------------------------------------------------------------

model InventoryBatch {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  variantId         String   @db.Uuid
  purchaseId        String?  @db.Uuid
  purchaseItemId    String?  @unique @db.Uuid
  quantity          Int // original quantity received
  remainingQuantity Int // remaining for FIFO consumption
  unitCost          Decimal  @db.Decimal(14, 2)
  purchaseDate      DateTime
  createdAt         DateTime @default(now())

  product      Product          @relation(fields: [productId], references: [id])
  variant      ProductVariant   @relation(fields: [variantId], references: [id])
  purchase     Purchase?        @relation(fields: [purchaseId], references: [id])
  purchaseItem PurchaseItem?    @relation(fields: [purchaseItemId], references: [id])
  allocations  CogsAllocation[]

  // FIFO scan: cheapest path is "this variant, oldest first, still has stock".
  @@index([variantId, purchaseDate, createdAt])
  @@index([variantId, remainingQuantity])
  @@index([productId])
  @@map("inventory_batches")
}

// ----------------------------------------------------------------------------
// Sales (stock OUT) — immutable after completion
// ----------------------------------------------------------------------------

model Sale {
  id                String     @id @default(uuid()) @db.Uuid
  invoiceNumber     String     @unique
  transactionNumber String     @unique
  userId            String     @db.Uuid
  cashSessionId     String?    @db.Uuid
  customerId        String?    @db.Uuid
  subtotal          Decimal    @db.Decimal(14, 2) // sum of line totals before discount
  discountTotal     Decimal    @db.Decimal(14, 2) @default(0)
  total             Decimal    @db.Decimal(14, 2) // payable
  // Payment settlement. CREDIT requires a customer; amountDue becomes receivable.
  paymentMethod     PaymentMethod @default(CASH)
  // Portion of `total` settled in cash at sale time (the till intake).
  amountPaid        Decimal    @db.Decimal(14, 2) @default(0)
  // Outstanding receivable for this sale (total - amountPaid). 0 for cash sales.
  amountDue         Decimal    @db.Decimal(14, 2) @default(0)
  cashReceived      Decimal    @db.Decimal(14, 2) // physical cash tendered
  changeGiven       Decimal    @db.Decimal(14, 2) @default(0)
  // Snapshot of total COGS at sale time (sum of product line COGS).
  totalCogs         Decimal    @db.Decimal(14, 2) @default(0)
  status            SaleStatus @default(COMPLETED)
  notes             String?
  // Idempotency: optional client-supplied key prevents duplicate processing.
  idempotencyKey    String?    @unique
  createdAt         DateTime   @default(now())

  // Void linkage (corrections never mutate the original sale).
  voidedAt       DateTime?
  voidReason     String?
  reversalOfId   String?   @unique @db.Uuid
  reversalOf     Sale?     @relation("SaleReversal", fields: [reversalOfId], references: [id])
  reversedBy     Sale?     @relation("SaleReversal")

  user        User        @relation(fields: [userId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  items       SaleItem[]
  returns     SaleReturn[]
  payments    CustomerPayment[]
  paymentAllocations CustomerPaymentAllocation[]

  @@index([userId])
  @@index([cashSessionId])
  @@index([customerId])
  @@index([createdAt])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id        String       @id @default(uuid()) @db.Uuid
  saleId    String       @db.Uuid
  itemType  SaleItemType
  productId String?      @db.Uuid
  variantId String?      @db.Uuid
  serviceId String?      @db.Uuid
  serviceVariantId String? @db.Uuid

  // --- immutable historical snapshots ---
  nameSnapshot      String
  unitPriceSnapshot Decimal  @db.Decimal(14, 2) // price per transacted unit
  // quantity is in the transacted unit (unitLabel). Base units (pieces) consumed
  // from inventory = quantity * unitSize.
  quantity          Int
  unitLabel         String   @default("pcs")
  unitSize          Int      @default(1)
  pages             Int? // for PER_PAGE services
  discount          Decimal  @db.Decimal(14, 2) @default(0)
  lineTotal         Decimal  @db.Decimal(14, 2)
  // COGS for product lines (FIFO). For services that consume products, holds
  // the sum of those products' FIFO cost too.
  lineCogs          Decimal  @db.Decimal(14, 2) @default(0)
  // Units already returned across all partial returns of this line.
  returnedQuantity  Int      @default(0)

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product        Product?        @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  service        Service?        @relation(fields: [serviceId], references: [id])
  serviceVariant ServiceVariant? @relation(fields: [serviceVariantId], references: [id])
  allocations    CogsAllocation[]
  // For service lines: snapshot of each product consumed, so a void can restore
  // every product this line drew down (a service may consume several products).
  consumptions   SaleItemConsumption[]
  returnItems    SaleReturnItem[]

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
  @@index([serviceId])
  @@index([serviceVariantId])
  @@map("sale_items")
}

// FIFO consumption detail: how each sold unit drew from which batch & at what cost.
model CogsAllocation {
  id               String  @id @default(uuid()) @db.Uuid
  saleItemId       String  @db.Uuid
  batchId          String  @db.Uuid
  // For service-line allocations: which consumed product (SaleItemConsumption)
  // this allocation belongs to. Null for plain product lines.
  saleItemConsumptionId String? @db.Uuid
  quantity         Int
  unitCost         Decimal @db.Decimal(14, 2)
  cost             Decimal @db.Decimal(14, 2) // quantity * unitCost
  // Units of this allocation reversed back to the batch via returns.
  returnedQuantity Int     @default(0)

  saleItem SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batch    InventoryBatch @relation(fields: [batchId], references: [id])
  consumption SaleItemConsumption? @relation(fields: [saleItemConsumptionId], references: [id], onDelete: Cascade)

  @@index([saleItemId])
  @@index([batchId])
  @@index([saleItemConsumptionId])
  @@map("cogs_allocations")
}

// Snapshot of one product a service line consumed (paper, lamination film, …).
// A single service line can have several — one per product in the option's BOM.
// Holds the base-unit quantity and FIFO cost drawn, so a void restores it exactly.
model SaleItemConsumption {
  id         String  @id @default(uuid()) @db.Uuid
  saleItemId String  @db.Uuid
  variantId  String  @db.Uuid
  productId  String  @db.Uuid
  qty        Int // base units consumed
  cogs       Decimal @db.Decimal(14, 2) @default(0)
  createdAt  DateTime @default(now())

  saleItem    SaleItem         @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  variant     ProductVariant   @relation(fields: [variantId], references: [id])
  allocations CogsAllocation[]

  @@index([saleItemId])
  @@index([variantId])
  @@map("sale_item_consumptions")
}

// ----------------------------------------------------------------------------
// Partial returns / refunds (immutable corrections, never mutate the sale)
// A sale stays COMPLETED; one or more SaleReturns record what came back.
// ----------------------------------------------------------------------------

model SaleReturn {
  id                String   @id @default(uuid()) @db.Uuid
  returnNumber      String   @unique
  saleId            String   @db.Uuid
  userId            String   @db.Uuid
  cashSessionId     String?  @db.Uuid
  reason            String
  totalRefund       Decimal  @db.Decimal(14, 2)
  // Portion of the refund applied to the customer's credit balance (store
  // credit) rather than paid out in cash. cashRefunded = totalRefund - creditApplied.
  creditApplied     Decimal  @db.Decimal(14, 2) @default(0)
  totalCogsReversed Decimal  @db.Decimal(14, 2) @default(0)
  createdAt         DateTime @default(now())

  sale        Sale             @relation(fields: [saleId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  cashSession CashSession?     @relation(fields: [cashSessionId], references: [id])
  items       SaleReturnItem[]

  @@index([saleId])
  @@index([userId])
  @@index([cashSessionId])
  @@index([createdAt])
  @@map("sale_returns")
}

model SaleReturnItem {
  id           String  @id @default(uuid()) @db.Uuid
  returnId     String  @db.Uuid
  saleItemId   String  @db.Uuid
  quantity     Int
  refundAmount Decimal @db.Decimal(14, 2)
  cogsReversed Decimal @db.Decimal(14, 2) @default(0)

  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])

  @@index([returnId])
  @@index([saleItemId])
  @@map("sale_return_items")
}

// ----------------------------------------------------------------------------
// Inventory movement ledger (every change, immutable)
// ----------------------------------------------------------------------------

model InventoryMovement {
  id            String                @id @default(uuid()) @db.Uuid
  productId     String                @db.Uuid
  variantId     String                @db.Uuid
  type          InventoryMovementType
  // Signed quantity: +in / -out. before + quantity = after.
  quantity      Int
  beforeQty     Int
  afterQty      Int
  unitCost      Decimal?              @db.Decimal(14, 2)
  userId        String?               @db.Uuid
  // Polymorphic reference to the originating document.
  referenceType String? // 'SALE' | 'PURCHASE' | 'ADJUSTMENT' | 'RETURN'
  referenceId   String?               @db.Uuid
  notes         String?
  createdAt     DateTime              @default(now())

  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  user    User?          @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([type])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

model InventoryAdjustment {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @db.Uuid
  variantId      String   @db.Uuid
  userId         String   @db.Uuid
  quantityChange Int // signed
  beforeQty      Int
  afterQty       Int
  reason         String
  // For positive adjustments we create a batch; track its cost for valuation.
  unitCost       Decimal? @db.Decimal(14, 2)
  createdAt      DateTime @default(now())

  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  user    User           @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([userId])
  @@map("inventory_adjustments")
}

// ----------------------------------------------------------------------------
// Expenses
// ----------------------------------------------------------------------------

// Admin-managed list of expense categories. Seeded with the original fixed set,
// but fully CRUD-able: admins may add their own, rename them, pick an icon and
// choose which ones staff may use.
model ExpenseCategory {
  id           String  @id @default(uuid()) @db.Uuid
  name         String  @unique
  // Material Symbols icon name shown next to the category in the UI.
  icon         String  @default("category")
  // "Petty cash": staff may record and see these. Fixed overheads (rent,
  // salary, electricity, internet) stay management-only by default.
  staffAllowed Boolean @default(false)
  // Archived categories keep their history but disappear from the pickers.
  isActive     Boolean @default(true)
  // Stable handle for categories the code itself resolves (OFFICE_SUPPLIES).
  // Null for admin-created ones; those carry no behaviour beyond their name.
  systemKey    String? @unique
  sortOrder    Int     @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses Expense[]

  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(uuid()) @db.Uuid
  categoryId    String          @db.Uuid
  amount        Decimal         @db.Decimal(14, 2)
  expenseDate   DateTime
  description   String?
  // Optional free-text vendor, used by itemized office purchases.
  supplierName  String?
  userId        String          @db.Uuid
  // Linked to the cash session if paid from the till.
  cashSessionId String?         @db.Uuid
  createdAt     DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id])
  cashSession CashSession?    @relation(fields: [cashSessionId], references: [id])
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  // Line items for itemized expenses (office/internal-use purchases).
  items       ExpenseItem[]

  @@index([categoryId])
  @@index([expenseDate])
  @@index([userId])
  @@index([cashSessionId])
  @@map("expenses")
}

// Line items of an itemized expense (office/internal-use purchase). Names are
// free text — these goods are consumed internally and never enter sellable stock.
model ExpenseItem {
  id        String  @id @default(uuid()) @db.Uuid
  expenseId String  @db.Uuid
  name      String
  quantity  Int
  unitCost  Decimal @db.Decimal(14, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("expense_items")
}

// ----------------------------------------------------------------------------
// Month-end close ("kufunga mahesabu")
// ----------------------------------------------------------------------------

// One row per calendar month that has been closed at least once. Closing
// snapshots the month's figures and freezes the entries behind them, so a
// reported profit cannot silently change after the fact. A row is only created
// on the first close; reopening flips the status and keeps the snapshot as a
// record of what was reported at the time.
model AccountingPeriod {
  id     String       @id @default(uuid()) @db.Uuid
  year   Int
  month  Int // 1-12
  status PeriodStatus @default(CLOSED)

  // Figures as computed at close time (never recomputed while closed).
  grossSales  Decimal @db.Decimal(14, 2)
  refunds     Decimal @db.Decimal(14, 2)
  revenue     Decimal @db.Decimal(14, 2)
  cogs        Decimal @db.Decimal(14, 2)
  grossProfit Decimal @db.Decimal(14, 2)
  expenses    Decimal @db.Decimal(14, 2)
  netProfit   Decimal @db.Decimal(14, 2)
  purchases   Decimal @db.Decimal(14, 2)
  saleCount   Int

  notes      String?
  closedAt   DateTime  @default(now())
  closedById String    @db.Uuid
  reopenedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  closedBy User @relation(fields: [closedById], references: [id])

  @@unique([year, month])
  @@index([status])
  @@map("accounting_periods")
}

// ----------------------------------------------------------------------------
// Cash management
// ----------------------------------------------------------------------------

model CashSession {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @db.Uuid
  openingBalance Decimal           @db.Decimal(14, 2)
  status         CashSessionStatus @default(OPEN)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?

  // Filled at close time (snapshot of computed values).
  expectedAmount Decimal? @db.Decimal(14, 2)
  actualAmount   Decimal? @db.Decimal(14, 2)
  variance       Decimal? @db.Decimal(14, 2)
  notes          String?

  user             User              @relation(fields: [userId], references: [id])
  sales            Sale[]
  expenses         Expense[]
  movements        CashMovement[]
  returns          SaleReturn[]
  purchases        Purchase[]
  customerPayments CustomerPayment[]
  supplierPayments SupplierPayment[]

  @@index([userId])
  @@index([status])
  @@index([openedAt])
  @@map("cash_sessions")
}

model CashMovement {
  id            String           @id @default(uuid()) @db.Uuid
  cashSessionId String           @db.Uuid
  type          CashMovementType
  amount        Decimal          @db.Decimal(14, 2)
  userId        String           @db.Uuid
  notes         String?
  createdAt     DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([cashSessionId])
  @@map("cash_movements")
}

// ----------------------------------------------------------------------------
// Document number sequences (gapless, concurrency-safe via row lock)
// One row per (type, period) e.g. INVOICE / 2026-06.
// ----------------------------------------------------------------------------

model DocumentSequence {
  id      String       @id @default(uuid()) @db.Uuid
  type    SequenceType
  period  String // e.g. "2026-06" or "ALL"
  current Int          @default(0)

  @@unique([type, period])
  @@map("document_sequences")
}

// ----------------------------------------------------------------------------
// Immutable audit log (append-only; never updated or deleted by the app)
// ----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String // e.g. 'SALE_CREATED', 'PRODUCT_UPDATED'
  entityType String // e.g. 'Sale', 'Product'
  entityId   String?
  // Structured before/after / context payload.
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ----------------------------------------------------------------------------
// Application settings (single row) — owner-editable branding such as the shop
// name shown across the app.
// ----------------------------------------------------------------------------

model AppSetting {
  id           String   @id @default("singleton")
  businessName String   @default("KJ Stationery")
  branchName   String   @default("Main Branch")
  // Automatic database backups to local disk (drive D on Windows by default).
  autoBackupEnabled Boolean  @default(false)
  // Local time of day (HH:mm, 24h) the daily backup should run.
  backupTime        String   @default("22:00")
  // Optional custom folder; null = OS default (D:\STMS-Backups on Windows).
  backupDir         String?
  // How many backup files to keep. Each new backup replaces the oldest once
  // this many exist — old copies are not worth the disk on a shop machine.
  backupKeep        Int      @default(3)
  lastBackupAt      DateTime?
  // "ok" after a successful run, or a short error message; null = never run.
  lastBackupStatus  String?
  lastBackupPath    String?
  updatedAt    DateTime @updatedAt

  @@map("app_settings")
}
