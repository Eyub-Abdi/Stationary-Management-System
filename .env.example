# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1
APP_NAME="KJ Stationery Management System"
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://stationery:stationery@localhost:5432/stationery?schema=public"

# ----------------------------------------------------------------------------
# JWT Authentication
# Generate strong secrets: `openssl rand -base64 64`
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace_with_strong_random_secret_access
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace_with_strong_random_secret_refresh
JWT_REFRESH_TTL=604800

# ----------------------------------------------------------------------------
# Redis (caching, rate limiting, idempotency cache)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=60

# ----------------------------------------------------------------------------
# Rate limiting
# ----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ----------------------------------------------------------------------------
# Observability (optional)
# ----------------------------------------------------------------------------
# External error tracking. Set a DSN AND `npm install @sentry/node` to ship 5xx
# errors to Sentry. Leave blank to disable (5xx are still logged with a stack).
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Backups (used by scripts/backup.sh)
# ----------------------------------------------------------------------------
BACKUP_DIR=./backups
RETENTION_DAYS=14

# ----------------------------------------------------------------------------
# Database integration tests (optional; scripts/test:int)
# A THROWAWAY database — it is migrated and written to by the test suite.
# ----------------------------------------------------------------------------
TEST_DATABASE_URL=

# ----------------------------------------------------------------------------
# Business
# ----------------------------------------------------------------------------
CURRENCY=TZS
# Bootstrap admin (used only by seed script)
SEED_ADMIN_EMAIL=admin@kjstationery.co.tz
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
